// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {uid} (Firebase Auth UID)
// Fields:
//   - uid: string (required) - The user's unique ID
//   - displayName: string (optional) - User's name
//   - email: string (required) - User's email
//   - photoURL: string (optional) - Profile picture URL
//   - bestTimes: map (optional) - { levelId: number }
//   - totalEscapes: number (optional) - Total successful runs
//   - createdAt: timestamp (required) - Creation time
//   - updatedAt: timestamp (required) - Last update time
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // All application reads and writes now flow through the NestJS API
    // using the Firebase Admin SDK. Browser clients should not access
    // Firestore collections directly.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
